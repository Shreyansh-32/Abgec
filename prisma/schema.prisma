generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id   Int    @id     @default(autoincrement())
  fullName   String
  gradYear    Int
  branch    String
  email     String  @unique
  password   String
  mobile     String
  organisation    String
  designation    String
  role      String
  location String?
  verified    Boolean   @default(false)
  isEmailVerified   Boolean   @default(false)
  profilePicture    String?
  proofPicture      String?
  otp   Otp[]
  mentor  Mentor?
  achievements  Achievement[]
  opportunities   Opportunity[]
}

model Otp{
  id    Int     @id     @default(autoincrement())
  userId   Int
  otp     String
  user    User    @relation(fields: [userId] , references: [id])
  expires   DateTime
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

model Mentor{
  id  Int   @id   @default(autoincrement())
  userId    Int   @unique
  isPaid    Boolean
  domain    String
  user    User    @relation(fields: [userId], references: [id])
  @@index([userId])
}

model Achievement{
  id  Int   @id   @default(autoincrement())
  userId    Int
  Achievement   String
  attachmentUrl   String?
  user    User    @relation(fields: [userId], references: [id])
  @@index([userId])
}

enum JobType{
  FullTime
  PartTime
  Internship
  Temporary
}

model Opportunity{
  id  Int   @id   @default(autoincrement())
  userId    Int
  JobTitle   String
  Location    String?
  RemotePosition  Boolean
  JobType   JobType
  Description   String
  ApplicationUrl  String?
  CompanyName   String
  Website     String?
  attachmentUrl   String?
  user    User    @relation(fields: [userId], references: [id])
  @@index([userId])
}